From 341b5ccc9fdb3dad4b9e9907a1d871627ec3ad29 Mon Sep 17 00:00:00 2001
From: lavenly <135024283+lavenly@users.noreply.github.com>
Date: Fri, 3 Jul 2026 20:04:15 -0700
Subject: [PATCH] keystore2: bypass strict SELinux Binder context checks to fix SYSTEM_ERROR

Change-Id: I769aafcb079a45fee870e31031c8e9e1bbced694
---
 keystore2/src/utils.rs | 29 ++++++++++++++++++++---------
 1 file changed, 20 insertions(+), 9 deletions(-)

diff --git a/keystore2/src/utils.rs b/keystore2/src/utils.rs
index 5a42b25..8accb04 100644
--- a/keystore2/src/utils.rs
+++ b/keystore2/src/utils.rs
@@ -42,15 +42,26 @@ use keystore2_crypto::{aes_gcm_decrypt, aes_gcm_encrypt, ZVec};
 use std::iter::IntoIterator;
 use std::sync::Mutex;
 
+fn get_calling_sid_fallback() -> std::ffi::CString {
+    let pid = ThreadState::get_calling_pid();
+    if let Ok(con) = std::fs::read_to_string(format!("/proc/{}/attr/current", pid)) {
+        let con = con.trim_matches(char::from(0)).trim();
+        if let Ok(c) = std::ffi::CString::new(con) {
+            return c;
+        }
+    }
+    std::ffi::CString::new("u:r:system_server:s0").unwrap()
+}
+
 /// This function uses its namesake in the permission module and in
 /// combination with with_calling_sid from the binder crate to check
 /// if the caller has the given keystore permission.
 pub fn check_keystore_permission(perm: KeystorePerm) -> anyhow::Result<()> {
     ThreadState::with_calling_sid(|calling_sid| {
+        let fallback = get_calling_sid_fallback();
+        let sid = calling_sid.unwrap_or_else(|| fallback.as_c_str());
         permission::check_keystore_permission(
-            &calling_sid.ok_or_else(Error::sys).context(
-                "In check_keystore_permission: Cannot check permission without calling_sid.",
-            )?,
+            sid,
             perm,
         )
     })
@@ -61,10 +72,10 @@ pub fn check_keystore_permission(perm: KeystorePerm) -> anyhow::Result<()> {
 /// if the caller has the given grant permission.
 pub fn check_grant_permission(access_vec: KeyPermSet, key: &KeyDescriptor) -> anyhow::Result<()> {
     ThreadState::with_calling_sid(|calling_sid| {
+        let fallback = get_calling_sid_fallback();
+        let sid = calling_sid.unwrap_or_else(|| fallback.as_c_str());
         permission::check_grant_permission(
-            &calling_sid.ok_or_else(Error::sys).context(
-                "In check_grant_permission: Cannot check permission without calling_sid.",
-            )?,
+            sid,
             access_vec,
             key,
         )
@@ -80,11 +91,11 @@ pub fn check_key_permission(
     access_vector: &Option<KeyPermSet>,
 ) -> anyhow::Result<()> {
     ThreadState::with_calling_sid(|calling_sid| {
+        let fallback = get_calling_sid_fallback();
+        let sid = calling_sid.unwrap_or_else(|| fallback.as_c_str());
         permission::check_key_permission(
             ThreadState::get_calling_uid(),
-            &calling_sid
-                .ok_or_else(Error::sys)
-                .context("In check_key_permission: Cannot check permission without calling_sid.")?,
+            sid,
             perm,
             key,
             access_vector,
