From 3c8faa5b07cce610340f587d8c1e6cfa2fcdf917 Mon Sep 17 00:00:00 2001
From: lavenly <135024283+lavenly@users.noreply.github.com>
Date: Sat, 20 Jun 2026 18:03:38 -0700
Subject: [PATCH] keystore: backport KeyStoreException for Android 12
 compatibility

Backports the Android 12 KeyStoreException class and the DEVICE_INITIAL_SDK_INT field to allow modern keystore daemons (like TEESimulator) to initialize without throwing ClassNotFoundException on legacy Android 10.

Signed-off-by: lavenly <135024283+lavenly@users.noreply.github.com>
---
 api/current.txt                               |  6 +++++
 core/java/android/os/Build.java               |  5 +++++
 .../security/keystore/KeyStoreException.java  | 22 +++++++++++++++++++
 3 files changed, 33 insertions(+)
 create mode 100644 keystore/java/android/security/keystore/KeyStoreException.java

diff --git a/api/current.txt b/api/current.txt
index cd78602d..3edebac2 100644
--- a/api/current.txt
+++ b/api/current.txt
@@ -40876,6 +40876,12 @@ package android.security.keystore {
     method @NonNull public android.security.keystore.KeyProtection.Builder setUserPresenceRequired(boolean);
   }
 
+  public class KeyStoreException extends java.lang.Exception {
+    ctor public KeyStoreException(int, String);
+    ctor public KeyStoreException(int, String, Throwable);
+    method public int getErrorCode();
+  }
+
   public class SecureKeyImportUnavailableException extends java.security.ProviderException {
     ctor public SecureKeyImportUnavailableException();
     ctor public SecureKeyImportUnavailableException(String);
diff --git a/core/java/android/os/Build.java b/core/java/android/os/Build.java
index 31403773..ef2bfe99 100755
--- a/core/java/android/os/Build.java
+++ b/core/java/android/os/Build.java
@@ -289,6 +289,11 @@ public class Build {
         public static final int FIRST_SDK_INT = SystemProperties
                 .getInt("ro.product.first_api_level", 0);
 
+        /**
+         * @hide
+         */
+        public static final int DEVICE_INITIAL_SDK_INT = FIRST_SDK_INT;
+
         /**
          * The developer preview revision of a prerelease SDK. This value will always
          * be <code>0</code> on production platform builds/devices.
diff --git a/keystore/java/android/security/keystore/KeyStoreException.java b/keystore/java/android/security/keystore/KeyStoreException.java
new file mode 100644
index 00000000..f9e9418c
--- /dev/null
+++ b/keystore/java/android/security/keystore/KeyStoreException.java
@@ -0,0 +1,22 @@
+package android.security.keystore;
+
+/**
+ * Thrown when a keystore operation fails.
+ */
+public class KeyStoreException extends Exception {
+    private final int mErrorCode;
+
+    public KeyStoreException(int errorCode, String message) {
+        super(message);
+        mErrorCode = errorCode;
+    }
+
+    public KeyStoreException(int errorCode, String message, Throwable cause) {
+        super(message, cause);
+        mErrorCode = errorCode;
+    }
+
+    public int getErrorCode() {
+        return mErrorCode;
+    }
+}
-- 
2.43.0

