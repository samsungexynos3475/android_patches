From 166194df2559e1f01c604007f9acbe510274b6ed Mon Sep 17 00:00:00 2001
From: lavenly <135024283+lavenly@users.noreply.github.com>
Date: Wed, 10 Jun 2026 05:38:16 -0700
Subject: [PATCH] hidl: touch: Add missing interface declaration to init script

In Android 10, `init` will silently refuse to start a vendor service
when requested by `hwservicemanager` if its initialization `.rc` file
is missing the HIDL interface declaration.

This fixes a severe issue where `system_server` hits a watchdog timeout
and continuously bootloops in Enforcing mode because the LineageOS
Touch HAL (`vendor.lineage.touch@1.0::IKeyDisabler`) never actually starts.

Generated with Antigravity (https://antigravity.google) using Gemini 3.1 Pro (High)

Signed-off-by: lavenly <135024283+lavenly@users.noreply.github.com>
---
 hidl/touch/vendor.lineage.touch@1.0-service.samsung.rc | 1 +
 1 file changed, 1 insertion(+)

diff --git a/hidl/touch/vendor.lineage.touch@1.0-service.samsung.rc b/hidl/touch/vendor.lineage.touch@1.0-service.samsung.rc
index 2f0d14f..4193c09 100644
--- a/hidl/touch/vendor.lineage.touch@1.0-service.samsung.rc
+++ b/hidl/touch/vendor.lineage.touch@1.0-service.samsung.rc
@@ -1,4 +1,5 @@
 service vendor.touch-hal-1-0-samsung /vendor/bin/hw/vendor.lineage.touch@1.0-service.samsung
+    interface vendor.lineage.touch@1.0::IKeyDisabler default
     class hal
     user system
     group system
-- 
2.43.0

