From 5663443c8c052914df6819a3201639956181b7f4 Mon Sep 17 00:00:00 2001
From: lavenly <135024283+lavenly@users.noreply.github.com>
Date: Wed, 10 Jun 2026 18:09:29 -0700
Subject: [PATCH 2/2] gralloc: Strip ION_FLAG_CACHED for CMA carveout
 allocations

The Exynos 3475 kernel's CMA heap allocation path unconditionally rejects `ION_FLAG_CACHED` with `-EINVAL`, causing a complete failure to allocate memory for hardware rendering buffers (such as the Camera Preview) when they request CMA memory.

This workaround unconditionally strips `ION_FLAG_CACHED` whenever allocating from the `ION_HEAP_CARVEOUT_MASK` heap. This allows the allocation to gracefully fallback and succeed as an uncached buffer, resolving black screen failures in the Camera HAL.

Generated with Antigravity (https://antigravity.google) using Gemini 3.1 Pro (High)

Signed-off-by: lavenly <135024283+lavenly@users.noreply.github.com>
---
 gralloc/gralloc.cpp | 19 ++++++++++++++++---
 1 file changed, 16 insertions(+), 3 deletions(-)

diff --git a/gralloc/gralloc.cpp b/gralloc/gralloc.cpp
index 7e27974..21b15ac 100644
--- a/gralloc/gralloc.cpp
+++ b/gralloc/gralloc.cpp
@@ -144,7 +144,10 @@ static unsigned int _select_heap(int usage)
             heap_mask = ION_HEAP_SYSTEM_MASK;
         else
             heap_mask = ION_HEAP_EXYNOS_CONTIG_MASK;
-    } else if (usage & GRALLOC_USAGE_CAMERA_RESERVED) {
+    } else if ((usage & GRALLOC_USAGE_CAMERA_RESERVED) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_WRITE) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_READ) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_ZSL)) {
         heap_mask = ION_HEAP_EXYNOS_CONTIG_MASK;
     } else {
         heap_mask = ION_HEAP_SYSTEM_MASK;
@@ -344,9 +347,12 @@ static int gralloc_alloc_yuv(int ionfd, int w, int h, int format,
         }
         else
             ion_flags |= ION_EXYNOS_MFC_OUTPUT_MASK;
-    } else if (usage & GRALLOC_USAGE_CAMERA_RESERVED)
+    } else if ((usage & GRALLOC_USAGE_CAMERA_RESERVED) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_WRITE) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_READ) ||
+               (usage & GRALLOC_USAGE_HW_CAMERA_ZSL)) {
         ion_flags |= ION_EXYNOS_MFC_OUTPUT_MASK;
-
+    }
     is_compressible = check_for_compression(w, h, format, usage);
     internal_format = gralloc_select_format(format, usage, is_compressible);
 
@@ -491,6 +497,13 @@ static int gralloc_alloc(alloc_device_t* dev,
             ion_flags |= ION_FLAG_SYNC_FORCE;
     }
 
+    /* WORKAROUND: The Exynos3475 CMA heap (ION_HEAP_EXYNOS_CONTIG_MASK)
+     * driver rejects allocations with ION_FLAG_CACHED.
+     * Strip cached flags if allocating from CMA to prevent EINVAL. */
+    if (_select_heap(usage) == ION_HEAP_EXYNOS_CONTIG_MASK) {
+        ion_flags &= ~(ION_FLAG_CACHED | ION_FLAG_CACHED_NEEDS_SYNC | ION_FLAG_SYNC_FORCE);
+    }
+
     if (usage & GRALLOC_USAGE_NOZEROED)
         ion_flags |= ION_FLAG_NOZEROED;
 
