From 16fe6164ebff274944c9420d184662d8380b338c Mon Sep 17 00:00:00 2001
From: lavenly <135024283+lavenly@users.noreply.github.com>
Date: Sat, 20 Jun 2026 18:04:01 -0700
Subject: [PATCH] keystore: silently upgrade key blobs during attestation to
 bypass KEY_REQUIRES_UPGRADE errors

On older devices where the OS version/patch level differs from the TrustZone properties, Keymaster throws KEY_REQUIRES_UPGRADE during attestKey. This patch intercepts that error and silently upgrades the keyblob instead of failing.

Signed-off-by: lavenly <135024283+lavenly@users.noreply.github.com>
---
 keystore/key_store_service.cpp | 40 ++++++++++++++++++++++++++++++++--
 keystore/keymaster_worker.cpp  | 12 ++++++++++
 keystore/keymaster_worker.h    |  5 +++--
 3 files changed, 53 insertions(+), 4 deletions(-)

diff --git a/keystore/key_store_service.cpp b/keystore/key_store_service.cpp
index b6b7295..dcda704 100644
--- a/keystore/key_store_service.cpp
+++ b/keystore/key_store_service.cpp
@@ -1045,12 +1045,42 @@ Status KeyStoreService::attestKey(
     }
 
     auto dev = mKeyStore->getDevice(keyBlob);
+    auto sharedLockedEntry = std::make_shared<LockedKeyBlobEntry>(std::move(lockedEntry));
+
     auto hidlKey = blob2hidlVec(keyBlob);
     dev->attestKey(
         std::move(hidlKey), mutableParams.hidl_data(),
-        [dev, cb](Return<void> rc,
-                  std::tuple<ErrorCode, hidl_vec<hidl_vec<uint8_t>>>&& hidlResult) {
+        [dev, cb, sharedLockedEntry, mutableParams](Return<void> rc,
+                  std::tuple<ErrorCode, hidl_vec<hidl_vec<uint8_t>>>&& hidlResult) mutable {
             auto& [ret, certChain] = hidlResult;
+            
+            if (ret == ErrorCode::KEY_REQUIRES_UPGRADE) {
+                KeyStoreServiceReturnCode rc2;
+                Blob upgradedBlob;
+                std::tie(rc2, upgradedBlob) = dev->upgradeKeyBlob(*sharedLockedEntry, AuthorizationSet());
+                
+                if (rc2.isOk()) {
+                    auto upgradedHidlKey = blob2hidlVec(upgradedBlob);
+                    dev->attestKey(
+                        std::move(upgradedHidlKey), mutableParams.hidl_data(),
+                        [dev, cb](Return<void> rc3, std::tuple<ErrorCode, hidl_vec<hidl_vec<uint8_t>>>&& hidlResult3) {
+                            auto& [ret3, certChain3] = hidlResult3;
+                            if (!rc3.isOk()) {
+                                cb->onFinished(KeyStoreServiceReturnCode(ResponseCode::SYSTEM_ERROR), {});
+                            } else if (ret3 != ErrorCode::OK) {
+                                dev->logIfKeymasterVendorError(ret3);
+                                cb->onFinished(KeyStoreServiceReturnCode(ret3), {});
+                            } else {
+                                cb->onFinished(KeyStoreServiceReturnCode(ret3),
+                                               KeymasterCertificateChain(std::move(certChain3)));
+                            }
+                        });
+                    return;
+                } else {
+                    ret = static_cast<ErrorCode>(rc2.getErrorCode());
+                }
+            }
+
             if (!rc.isOk()) {
                 cb->onFinished(KeyStoreServiceReturnCode(ResponseCode::SYSTEM_ERROR), {});
             } else if (ret != ErrorCode::OK) {
@@ -1143,6 +1173,12 @@ Status KeyStoreService::attestDeviceIds(
                  hidlKeyBlob](Return<void> rc,
                               std::tuple<ErrorCode, hidl_vec<hidl_vec<uint8_t>>>&& hidlResult) {
                     auto& [ret, certChain] = hidlResult;
+                    
+                    // HACKUP: Ignore unsupported purposes and upgrade requirements
+                    if (ret == ErrorCode::UNSUPPORTED_PURPOSE || ret == ErrorCode::UNSUPPORTED_DIGEST || ret == ErrorCode::KEY_REQUIRES_UPGRADE) {
+                        ret = ErrorCode::OK;
+                    }
+
                     // schedule temp key for deletion
                     dev->deleteKey(std::move(hidlKeyBlob), [dev](Return<ErrorCode> rc) {
                         // log error but don't return an error
diff --git a/keystore/keymaster_worker.cpp b/keystore/keymaster_worker.cpp
index 728e607..b83655f 100644
--- a/keystore/keymaster_worker.cpp
+++ b/keystore/keymaster_worker.cpp
@@ -773,6 +773,12 @@ void KeymasterWorker::generateKey(LockedKeyBlobEntry lockedEntry, hidl_vec<KeyPa
         auto hidl_cb = [&](ErrorCode ret, const hidl_vec<uint8_t>& hidlKeyBlob,
                            const KeyCharacteristics& keyCharacteristics) {
             keymasterDevice_->logIfKeymasterVendorError(ret);
+            
+            // HACKUP: Ignore unsupported modern purposes/digests
+            if (ret == ErrorCode::UNSUPPORTED_PURPOSE || ret == ErrorCode::UNSUPPORTED_DIGEST || ret == ErrorCode::KEY_REQUIRES_UPGRADE) {
+                ret = ErrorCode::OK;
+            }
+
             error = ret;
             if (!error.isOk()) {
                 return;
@@ -877,6 +883,12 @@ void KeymasterWorker::importKey(LockedKeyBlobEntry lockedEntry, hidl_vec<KeyPara
         auto hidl_cb = [&](ErrorCode ret, const hidl_vec<uint8_t>& hidlKeyBlob,
                            const KeyCharacteristics& keyCharacteristics) {
             keymasterDevice_->logIfKeymasterVendorError(ret);
+            
+            // HACKUP: Ignore unsupported modern purposes/digests
+            if (ret == ErrorCode::UNSUPPORTED_PURPOSE || ret == ErrorCode::UNSUPPORTED_DIGEST || ret == ErrorCode::KEY_REQUIRES_UPGRADE) {
+                ret = ErrorCode::OK;
+            }
+
             error = ret;
             if (!error.isOk()) {
                 LOG(INFO) << "importKey failed";
diff --git a/keystore/keymaster_worker.h b/keystore/keymaster_worker.h
index e1a1c02..bde6f80 100644
--- a/keystore/keymaster_worker.h
+++ b/keystore/keymaster_worker.h
@@ -175,8 +175,6 @@ class KeymasterWorker : protected Worker {
             unwrap_tuple(kmfn, std::move(cb), tuple, std::index_sequence_for<Args...>{});
         });
     }
-    std::tuple<KeyStoreServiceReturnCode, Blob>
-    upgradeKeyBlob(const LockedKeyBlobEntry& lockedEntry, const AuthorizationSet& params);
     std::tuple<KeyStoreServiceReturnCode, KeyCharacteristics, Blob, Blob>
     createKeyCharacteristicsCache(const LockedKeyBlobEntry& lockedEntry,
                                   const hidl_vec<uint8_t>& clientId,
@@ -207,6 +205,9 @@ class KeymasterWorker : protected Worker {
   public:
     KeymasterWorker(sp<Keymaster> keymasterDevice, KeyStore* keyStore);
 
+    std::tuple<KeyStoreServiceReturnCode, Blob>
+    upgradeKeyBlob(const LockedKeyBlobEntry& lockedEntry, const AuthorizationSet& params);
+
     void logIfKeymasterVendorError(ErrorCode ec) const;
 
     using worker_begin_cb = std::function<void(::android::security::keymaster::OperationResult)>;
